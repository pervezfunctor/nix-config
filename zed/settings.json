{
  "diff_view_style": "split",

  "auto_install_extensions": {
    "basher": true,
    "catppuccin": true,
    "catppuccin-blur": true,
    "catppuccin-icons": true,
    "docker-compose": true,
    "dockerfile": true,
    "fish": true,
    "kdl": true,
    "make": true,
    "neocmake": true,
    "nix": true,
    "nu": true,
  },

  "cli_default_open_behavior": "new_window",
  "icon_theme": {
    "mode": "light",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "ui_font_size": 15,
  "ui_font_family": "Cascadia Code NF",
  // "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_family": "Cascadia Mono NF",
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },

  "ensure_final_newline_on_save": true,
  "remove_trailing_whitespace_on_save": true,
  "format_on_save": "on",
  "tab_size": 2,

  "languages": {
    "C++": {
      "tab_size": 4,
    },
    "Rust": {
      "tab_size": 4,
    },
  },
}
